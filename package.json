{
  "name": "typed-config-plugins",
  "version": "0.5.5",
  "description": "Type-safe helpers and generated typings for Expo config plugins in app.config.ts.",
  "author": {
    "name": "WookieFPV (Lukas Müller)",
    "url": "https://github.com/WookieFPV"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/WookieFPV/typed-config-plugins"
  },
  "homepage": "https://github.com/WookieFPV/typed-config-plugins#readme",
  "bugs": {
    "url": "https://github.com/WookieFPV/typed-config-plugins/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "expo",
    "config-plugin",
    "react-native",
    "typescript",
    "typings"
  ],
  "workspaces": [
    ".",
    "packageList"
  ],
  "license": "MIT",
  "module": "dist/plugin.js",
  "type": "module",
  "types": "dist/plugin.d.ts",
  "exports": {
    "types": "./dist/plugin.d.ts",
    "default": "./dist/plugin.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "update": "bun src/codegenPipeline/run.ts",
    "find": "bun run src/codegenPipeline/searchTypes/findTypesCli.ts",
    "github": "bun run src/codegenPipeline/githubSearch/findRepos.ts",
    "build:dev": "tsup --watch",
    "changeset": "changeset",
    "lint": "bunx biome check --fix --unsafe",
    "lint:CI": "bunx biome check",
    "release": "changeset publish",
    "typecheck": "tsc",
    "version-packages": "changeset version",
    "prepublishOnly": "bun run lint:CI && bun run typecheck && bun run build"
  },
  "devDependencies": {
    "@babel/parser": "8.0.4",
    "@babel/traverse": "8.0.4",
    "@babel/types": "8.0.4",
    "@biomejs/biome": "2.5.4",
    "@changesets/cli": "2.31.1",
    "@expo/config-plugins": "57.0.5",
    "@octokit/rest": "22.0.1",
    "@types/bun": "1.3.14",
    "@types/npm-registry-fetch": "8.0.9",
    "@types/resolve": "1.20.6",
    "es-toolkit": "1.49.0",
    "lefthook": "2.1.10",
    "npm-registry-fetch": "20.0.1",
    "ora": "9.4.1",
    "p-queue": "9.3.1",
    "resolve": "1.22.12",
    "tsup": "8.5.1",
    "typescript": "5.9.3"
  },
  "patchedDependencies": {
    "instabug-reactnative@16.0.2": "patches/instabug-reactnative@16.0.2.patch",
    "onesignal-expo-plugin@2.0.3": "patches/onesignal-expo-plugin@2.0.3.patch",
    "instabug-reactnative@16.0.3": "patches/instabug-reactnative@16.0.3.patch",
    "react-native-spotlight-search@2.2.0": "patches/react-native-spotlight-search@2.2.0.patch",
    "react-native-ota-hot-update@2.3.4": "patches/react-native-ota-hot-update@2.3.4.patch",
    "expo-whisper@1.0.10": "patches/expo-whisper@1.0.10.patch"
  },
  "overrides": {
    "@types/node": "24.9.1"
  }
}
